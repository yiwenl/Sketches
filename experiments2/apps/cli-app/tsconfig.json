{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@experiments2/utils": ["../../libs/utils/index.ts"],
      "gl-matrix": ["../../node_modules/gl-matrix"],
      "scheduling": ["../../node_modules/scheduling"],
      "object-assign": ["../../node_modules/object-assign"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
